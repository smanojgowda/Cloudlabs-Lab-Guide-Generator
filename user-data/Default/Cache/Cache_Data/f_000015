№╗┐<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lab Guide Recorder</title>
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <style>
    :root {
      --bg: #0a0e17;
      --bg-card: #111827;
      --border: #1e293b;
      --text: #e2e8f0;
      --text-muted: #94a3b8;
      --accent: #22d3ee;
      --red: #ef4444;
      --green: #22c55e;
      --orange: #f59e0b;
      --font: 'Segoe UI', system-ui, sans-serif;
      --mono: 'Cascadia Code', 'Fira Code', monospace;
      --radius: 10px;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: var(--font); background: var(--bg); color: var(--text); min-height: 100vh; }

    header {
      background: linear-gradient(135deg, #0f172a, #1e1b4b, #0f172a);
      border-bottom: 1px solid var(--border);
      padding: 1.2rem 2rem;
      display: flex; align-items: center; justify-content: space-between;
    }
    header h1 {
      font-size: 1.4rem;
      background: linear-gradient(90deg, var(--accent), #818cf8);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }
    .status-badge {
      padding: 0.3rem 0.8rem; border-radius: 20px; font-size: 0.8rem; font-weight: 600;
    }
    .status-idle { background: #1e293b; color: var(--text-muted); }
    .status-recording { background: rgba(239,68,68,0.2); color: var(--red); animation: pulse 1.5s infinite; }
    .status-generating { background: rgba(245,158,11,0.2); color: var(--orange); }
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.6; } }

    .container { max-width: 1200px; margin: 0 auto; padding: 1.5rem 2rem; }

    /* Setup Panel */
    .setup-panel {
      background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 1.5rem; margin-bottom: 1.5rem;
    }
    .setup-panel h2 { font-size: 1.1rem; margin-bottom: 1rem; }
    .form-row { display: flex; gap: 1rem; margin-bottom: 0.8rem; flex-wrap: wrap; }
    .form-group { flex: 1; min-width: 200px; }
    .form-group label { display: block; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.3rem; }
    input, textarea {
      width: 100%; padding: 0.6rem 0.8rem; background: #0f1729; border: 1px solid var(--border);
      border-radius: 6px; color: var(--text); font-family: var(--font); font-size: 0.9rem;
    }
    input:focus, textarea:focus { outline: none; border-color: var(--accent); }
    textarea { resize: vertical; min-height: 60px; }

    .btn {
      padding: 0.6rem 1.2rem; border: none; border-radius: 6px; cursor: pointer;
      font-weight: 600; font-size: 0.85rem; transition: all 0.2s;
    }
    .btn-primary { background: var(--accent); color: #000; }
    .btn-primary:hover { background: #06b6d4; }
    .btn-primary:disabled { opacity: 0.4; cursor: not-allowed; }
    .btn-danger { background: var(--red); color: #fff; }
    .btn-danger:hover { background: #dc2626; }
    .btn-success { background: var(--green); color: #fff; }
    .btn-success:hover { background: #16a34a; }
    .btn-ghost { background: transparent; color: var(--text-muted); border: 1px solid var(--border); }
    .btn-ghost:hover { background: #1e293b; color: var(--text); }

    .btn-row { display: flex; gap: 0.8rem; margin-top: 1rem; flex-wrap: wrap; }

    /* Recording Controls */
    .recording-controls {
      background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 1.2rem 1.5rem; margin-bottom: 1.5rem;
      display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
    }
    .recording-controls .capture-desc {
      flex: 1; min-width: 200px;
    }

    /* Steps Log */
    .steps-panel {
      background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 1.5rem; margin-bottom: 1.5rem;
    }
    .steps-panel h2 { font-size: 1.1rem; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; }
    .step-count { font-size: 0.8rem; background: var(--accent); color: #000; padding: 0.1rem 0.5rem; border-radius: 10px; }

    .step-list { list-style: none; }
    .step-item {
      display: flex; align-items: center; gap: 1rem; padding: 0.8rem;
      border-bottom: 1px solid var(--border); transition: background 0.15s;
    }
    .step-item:hover { background: rgba(255,255,255,0.03); }
    .step-item:last-child { border-bottom: none; }
    .step-num {
      width: 32px; height: 32px; border-radius: 50%; background: rgba(34,211,238,0.15);
      color: var(--accent); display: flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: 0.85rem; flex-shrink: 0;
    }
    .step-info { flex: 1; }
    .step-desc { font-size: 0.9rem; }
    .step-meta { font-size: 0.75rem; color: var(--text-muted); margin-top: 0.2rem; }
    .step-thumb {
      width: 80px; height: 50px; border-radius: 4px; object-fit: cover; border: 1px solid var(--border);
      cursor: pointer;
    }
    .step-actions { display: flex; gap: 0.3rem; }
    .step-actions button {
      background: transparent; border: none; color: var(--text-muted); cursor: pointer;
      padding: 0.3rem; border-radius: 4px; font-size: 0.8rem;
    }
    .step-actions button:hover { background: #1e293b; color: var(--text); }

    .empty-state { text-align: center; color: var(--text-muted); padding: 2rem; font-size: 0.9rem; }

    /* Guide Output */
    .guide-panel {
      background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 1.5rem; margin-bottom: 1.5rem;
    }
    .guide-panel h2 { font-size: 1.1rem; margin-bottom: 1rem; }
    .guide-actions { display: flex; gap: 0.8rem; margin-bottom: 1rem; }
    .tab-group { display: flex; border-bottom: 1px solid var(--border); margin-bottom: 1rem; }
    .tab-btn {
      background: none; border: none; color: var(--text-muted); padding: 0.6rem 1rem;
      cursor: pointer; border-bottom: 2px solid transparent; font-size: 0.85rem;
    }
    .tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }
    .guide-preview {
      padding: 1rem; background: #0f1729; border-radius: 6px; max-height: 600px; overflow-y: auto;
      line-height: 1.7; font-size: 0.9rem;
    }
    .guide-preview img { max-width: 100%; border-radius: 4px; margin: 0.5rem 0; }
    .guide-preview h1 { font-size: 1.5rem; margin-bottom: 0.5rem; }
    .guide-preview h2 { font-size: 1.2rem; margin: 1rem 0 0.5rem; color: var(--accent); }
    .guide-preview h3 { font-size: 1.05rem; margin: 1rem 0 0.5rem; }
    .guide-preview code { background: #1e293b; padding: 0.15rem 0.4rem; border-radius: 3px; font-family: var(--mono); }
    .guide-preview blockquote { border-left: 3px solid var(--orange); padding-left: 1rem; color: var(--text-muted); margin: 0.5rem 0; }
    .guide-raw {
      padding: 1rem; background: #0f1729; border-radius: 6px; max-height: 600px; overflow-y: auto;
      font-family: var(--mono); font-size: 0.8rem; white-space: pre-wrap; color: var(--text-muted);
    }

    /* Edit Modal */
    .modal-overlay {
      display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 100;
      align-items: center; justify-content: center;
    }
    .modal-overlay.active { display: flex; }
    .modal {
      background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 1.5rem; width: 90%; max-width: 500px;
    }
    .modal h3 { margin-bottom: 1rem; }
    .modal .btn-row { justify-content: flex-end; }

    /* Screenshot Preview Modal */
    .img-modal { cursor: pointer; }
    .img-modal-overlay {
      display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.85); z-index: 200;
      align-items: center; justify-content: center; cursor: pointer;
    }
    .img-modal-overlay.active { display: flex; }
    .img-modal-overlay img { max-width: 95%; max-height: 95%; border-radius: 8px; }
  </style>
</head>
<body>

  <header>
    <h1>Lab Guide Recorder</h1>
    <span id="statusBadge" class="status-badge status-idle">Idle</span>
  </header>

  <div class="container">
    <!-- Setup -->
    <div id="setupPanel" class="setup-panel">
      <h2>New Recording Session</h2>
      <div class="form-row">
        <div class="form-group">
          <label>Lab Title</label>
          <input id="labTitle" placeholder="Lab 01: Create a Linux Virtual Machine" value="Lab 01: Create a Simple Storage Account">
        </div>
        <div class="form-group" style="max-width:300px;">
          <label>Start URL</label>
          <input id="startUrl" placeholder="https://portal.azure.com" value="https://portal.azure.com">
        </div>
      </div>
      <div class="form-group">
        <label>Lab Description</label>
        <textarea id="labDesc" placeholder="Describe what this lab covers..."></textarea>
      </div>
      <div class="btn-row">
        <button class="btn btn-primary" onclick="startRecording()">Start Recording</button>
      </div>
    </div>

    <!-- Recording Controls (hidden until active) -->
    <div id="recordingControls" class="recording-controls" style="display:none;">
      <div style="flex:1;font-size:0.85rem;color:var(--text-muted);">
        A <strong style="color:var(--accent);">Lab Recorder</strong> window is docked to the right of the browser.
        Use it to capture steps directly, or press <kbd style="background:#1e293b;padding:2px 6px;border-radius:3px;font-size:0.8rem;">Ctrl+Shift+C</kbd> in the recorder window.
        You can also capture from here:
      </div>
      <input id="captureDesc" class="capture-desc" placeholder="Step description (optional Рђћ prefer the in-browser overlay)">
      <button class="btn btn-primary" onclick="captureStep()">Capture Step</button>
      <button class="btn btn-success" onclick="generateGuide()">Generate Guide</button>
      <button class="btn btn-ghost" onclick="cancelRecording()">Cancel</button>
    </div>

    <!-- Steps List -->
    <div id="stepsPanel" class="steps-panel" style="display:none;">
      <h2>Recorded Steps <span id="stepCount" class="step-count">0</span></h2>
      <ul id="stepList" class="step-list">
        <li class="empty-state">No steps captured yet. Perform actions in the browser, then click "Capture Step".</li>
      </ul>
    </div>

    <!-- Guide Output (hidden until generated) -->
    <div id="guidePanel" class="guide-panel" style="display:none;">
      <h2>Generated Lab Guide</h2>
      <div class="guide-actions">
        <button class="btn btn-ghost" onclick="copyMarkdown()">Copy Markdown</button>
        <button class="btn btn-ghost" onclick="downloadMarkdown()">Download .md</button>
      </div>
      <div class="tab-group">
        <button class="tab-btn active" onclick="showTab('preview')">Preview</button>
        <button class="tab-btn" onclick="showTab('raw')">Raw Markdown</button>
      </div>
      <div id="guidePreview" class="guide-preview"></div>
      <div id="guideRaw" class="guide-raw" style="display:none;"></div>
    </div>
  </div>

  <!-- Edit Step Modal -->
  <div id="editModal" class="modal-overlay">
    <div class="modal">
      <h3>Edit Step Description</h3>
      <input id="editDesc" style="margin-bottom:1rem;">
      <div class="btn-row">
        <button class="btn btn-ghost" onclick="closeEditModal()">Cancel</button>
        <button class="btn btn-primary" onclick="saveEditStep()">Save</button>
      </div>
    </div>
  </div>

  <!-- Image Preview Modal -->
  <div id="imgModal" class="img-modal-overlay" onclick="this.classList.remove('active')">
    <img id="imgModalSrc" src="">
  </div>

  <script>
    let currentMarkdown = '';
    let editingStepNum = null;

    // ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг API helpers ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг
    async function api(path, opts = {}) {
      const res = await fetch(`/api${path}`, {
        headers: { 'Content-Type': 'application/json' },
        ...opts,
        body: opts.body ? JSON.stringify(opts.body) : undefined,
      });
      return res.json();
    }

    // ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг Session ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг
    async function startRecording() {
      const title = document.getElementById('labTitle').value.trim();
      const url = document.getElementById('startUrl').value.trim();
      const description = document.getElementById('labDesc').value.trim();

      if (!title) { alert('Please enter a lab title.'); return; }

      setBadge('recording', 'Recording...');
      try {
        const data = await api('/session/start', {
          method: 'POST',
          body: { url: url || undefined, title, description },
        });
        if (data.error) { alert(data.error); setBadge('idle', 'Idle'); return; }

        document.getElementById('setupPanel').style.display = 'none';
        document.getElementById('recordingControls').style.display = 'flex';
        document.getElementById('stepsPanel').style.display = 'block';
        startPolling();
      } catch (err) {
        alert('Failed to start: ' + err.message);
        setBadge('idle', 'Idle');
      }
    }

    async function captureStep() {
      const desc = document.getElementById('captureDesc').value.trim();
      try {
        const step = await api('/session/capture', {
          method: 'POST',
          body: { description: desc || undefined },
        });
        if (step.error) { alert(step.error); return; }

        document.getElementById('captureDesc').value = '';
        addStepToList(step);
      } catch (err) {
        alert('Capture failed: ' + err.message);
      }
    }

    async function generateGuide() {
      const title = document.getElementById('labTitle').value.trim();
      const description = document.getElementById('labDesc').value.trim();

      setBadge('generating', 'Generating...');
      try {
        const data = await api('/session/generate', {
          method: 'POST',
          body: { title, description },
        });
        if (data.error) { alert(data.error); setBadge('recording', 'Recording...'); return; }

        currentMarkdown = data.markdown;
        showGuide(data.markdown);
        document.getElementById('recordingControls').style.display = 'none';
        setBadge('idle', 'Complete');
      } catch (err) {
        alert('Generation failed: ' + err.message);
        setBadge('recording', 'Recording...');
      }
    }

    async function cancelRecording() {
      if (!confirm('Cancel recording? Steps will be lost.')) return;
      await api('/session/cancel', { method: 'POST' });
      location.reload();
    }

    async function deleteStep(num) {
      await api(`/session/step/${num}`, { method: 'DELETE' });
      refreshSteps();
    }

    function openEditModal(num, desc) {
      editingStepNum = num;
      document.getElementById('editDesc').value = desc;
      document.getElementById('editModal').classList.add('active');
    }

    function closeEditModal() {
      document.getElementById('editModal').classList.remove('active');
      editingStepNum = null;
    }

    async function saveEditStep() {
      if (editingStepNum == null) return;
      const desc = document.getElementById('editDesc').value.trim();
      if (!desc) return;
      await api(`/session/step/${editingStepNum}`, {
        method: 'PUT',
        body: { description: desc },
      });
      closeEditModal();
      refreshSteps();
    }

    async function refreshSteps() {
      const data = await api('/session');
      renderSteps(data.steps || []);
    }

    // ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг UI Rendering ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг
    function addStepToList(step) {
      const list = document.getElementById('stepList');
      // Remove empty state
      const empty = list.querySelector('.empty-state');
      if (empty) empty.remove();

      const li = document.createElement('li');
      li.className = 'step-item';
      li.id = `step-${step.stepNumber}`;
      li.innerHTML = `
        <div class="step-num">${step.stepNumber}</div>
        <div class="step-info">
          <div class="step-desc">${escapeHtml(step.description)}</div>
          <div class="step-meta">${step.pageTitle || ''} &bull; ${new Date(step.timestamp).toLocaleTimeString()}</div>
        </div>
        ${step.screenshotFilename ? `<img class="step-thumb" src="/screenshots/${step.screenshotFilename}" onclick="showImage(this.src)" alt="Step ${step.stepNumber}">` : ''}
        <div class="step-actions">
          <button title="Edit" onclick="openEditModal(${step.stepNumber}, '${escapeAttr(step.description)}')">&#9998;</button>
          <button title="Delete" onclick="deleteStep(${step.stepNumber})">&#10005;</button>
        </div>
      `;
      list.appendChild(li);

      const count = list.querySelectorAll('.step-item').length;
      document.getElementById('stepCount').textContent = count;
    }

    function renderSteps(steps) {
      const list = document.getElementById('stepList');
      if (!steps.length) {
        list.innerHTML = '<li class="empty-state">No steps captured yet.</li>';
        document.getElementById('stepCount').textContent = '0';
        return;
      }
      list.innerHTML = '';
      steps.forEach(s => addStepToList(s));
    }

    function showGuide(markdown) {
      document.getElementById('guidePanel').style.display = 'block';
      document.getElementById('guidePreview').innerHTML = marked.parse(markdown);
      document.getElementById('guideRaw').textContent = markdown;
    }

    function showTab(tab) {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      event.target.classList.add('active');
      document.getElementById('guidePreview').style.display = tab === 'preview' ? 'block' : 'none';
      document.getElementById('guideRaw').style.display = tab === 'raw' ? 'block' : 'none';
    }

    function showImage(src) {
      document.getElementById('imgModalSrc').src = src;
      document.getElementById('imgModal').classList.add('active');
    }

    function setBadge(cls, text) {
      const badge = document.getElementById('statusBadge');
      badge.className = `status-badge status-${cls}`;
      badge.textContent = text;
    }

    function copyMarkdown() {
      navigator.clipboard.writeText(currentMarkdown).then(() => {
        alert('Copied to clipboard!');
      });
    }

    function downloadMarkdown() {
      const blob = new Blob([currentMarkdown], { type: 'text/markdown' });
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = 'lab-guide.md';
      a.click();
      URL.revokeObjectURL(a.href);
    }

    function escapeHtml(t) {
      const d = document.createElement('div');
      d.textContent = t;
      return d.innerHTML;
    }

    function escapeAttr(t) {
      return t.replace(/'/g, "\\'").replace(/"/g, '&quot;');
    }

    // Check if there's an active session on page load
    let pollInterval = null;
    (async () => {
      try {
        const data = await api('/session');
        if (data.active) {
          document.getElementById('setupPanel').style.display = 'none';
          document.getElementById('recordingControls').style.display = 'flex';
          document.getElementById('stepsPanel').style.display = 'block';
          setBadge('recording', 'Recording...');
          renderSteps(data.steps || []);
          startPolling();
        }
      } catch { /* server not ready yet */ }
    })();

    // Poll for new steps captured from the side panel extension
    let lastKnownCount = 0;
    function startPolling() {
      if (pollInterval) return;
      pollInterval = setInterval(async () => {
        try {
          const data = await api('/session');
          if (!data.active) { clearInterval(pollInterval); pollInterval = null; return; }
          if (data.stepCount !== lastKnownCount) {
            lastKnownCount = data.stepCount;
            renderSteps(data.steps || []);
          }
        } catch { /* ignore */ }
      }, 2000);
    }
  </script>
</body>
</html>
