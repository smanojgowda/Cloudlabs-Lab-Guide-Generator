{
  "name": "spektra-lab-studio",
  "version": "5.0.0",
  "description": "AI-powered Azure lab guide generator with ARM template planning",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_OPTIONS=--import=tsx/esm electron electron/main.ts\"",
    "electron:build": "npm run build && electron-builder",
    "server:dev": "tsx watch server/index.ts",
    "lint": "eslint src/ server/ electron/"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "openai": "^4.85.0",
    "sharp": "^0.33.5",
    "simple-git": "^3.27.0",
    "winston": "^3.17.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.0",
    "eslint": "^9.0.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.spektra.lab-studio",
    "productName": "Spektra Lab Studio",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "dist-server/**/*"
    ],
    "directories": {
      "output": "release"
    }
  }
}
